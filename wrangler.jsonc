{
  "name": "memory-map",
  "compatibility_date": "2025-01-01",
  "main": ".open-next/worker.js",
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS",
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "memory-map-db",
      "database_id": "PLACEHOLDER_REPLACE_AFTER_WRANGLER_D1_CREATE",
    },
  ],
}
